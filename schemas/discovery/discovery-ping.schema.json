{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencognitionprotocol.org/schemas/v1/discovery/discovery-ping.schema.json",
  "title": "OCP Discovery Ping Payload",
  "description": "Payload for a discovery_ping broadcast message. Agents announce their presence and capabilities on the network.",
  "type": "object",
  "required": ["capabilities", "domains"],
  "properties": {
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^cap:"
      },
      "description": "Capability identifiers this agent supports."
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Domains this agent operates in."
    },
    "trust_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "description": "Agent's current trust level."
    },
    "display_name": {
      "type": "string",
      "maxLength": 256,
      "description": "Human-readable agent name."
    },
    "version": {
      "type": "string",
      "description": "Agent software version."
    }
  },
  "additionalProperties": false
}
