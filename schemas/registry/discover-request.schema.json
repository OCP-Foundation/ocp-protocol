{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencognitionprotocol.org/schemas/v1/registry/discover-request.schema.json",
  "title": "OCP Registry Discovery Request",
  "description": "Request body for the registry discover endpoint.",
  "type": "object",
  "required": ["filters"],
  "properties": {
    "filters": {
      "type": "object",
      "properties": {
        "domains": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Filter by domain(s)."
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Filter by capability ID(s)."
        },
        "min_trust_level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4,
          "description": "Minimum trust level."
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "suspended"],
          "default": "active"
        },
        "extensions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Filter by supported extensions."
        }
      },
      "additionalProperties": false
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20,
      "description": "Maximum results to return."
    },
    "offset": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Pagination offset."
    },
    "sort_by": {
      "type": "string",
      "enum": ["trust_level", "registered_at", "last_seen_at"],
      "default": "trust_level",
      "description": "Sort field."
    },
    "sort_order": {
      "type": "string",
      "enum": ["asc", "desc"],
      "default": "desc"
    }
  },
  "additionalProperties": false
}
